# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/ai_publisher"

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# OAuth – Google (console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth – GitHub (github.com/settings/developers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Magic Links – Resend (resend.com)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs from your Stripe dashboard
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_CREDITS_50_PRICE_ID="price_..."
STRIPE_CREDITS_200_PRICE_ID="price_..."

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Upstash Redis (upstash.com) ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://...upstash.io"
UPSTASH_REDIS_REST_TOKEN="..."
